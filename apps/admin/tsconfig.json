{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "strict": true,
    "noEmit": true,
    "target": "ESNext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "isolatedModules": true,
    "paths": {
      "@ui/components/*": ["../../lib/typescript/ui/components/src/*"],
      "@lib/api-client/*": ["../../lib/typescript/api-client/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"]
}
